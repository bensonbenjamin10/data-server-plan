# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database (Railway provides DATABASE_URL)
DATABASE_URL=postgresql://user:password@localhost:5432/org_data

# Auth (JWT signing - use a strong random string in production)
JWT_SECRET=your-secret-key-change-in-production

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=data-joe

# Resend (transactional email)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@finjoe.app

# Dev bypass (SKIP_AUTH=1 skips JWT, uses dev-user-id / dev-org-id from seed)
SKIP_AUTH=0
